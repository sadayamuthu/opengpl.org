{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opengpl.org/schema/v0.1/schema.json",
  "title": "OpenGPL v0.1 Policy Schema",
  "description": "JSON Schema for validating OpenGPL v0.1 policy documents",
  "type": "object",
  "required": ["opengpl", "policy", "version", "description", "status", "owner", "applies_to", "audit", "enforcement"],

  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Lowercase letters, numbers, and hyphens only"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "description": "Semantic version: MAJOR.MINOR.PATCH"
    },
    "isoDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date: YYYY-MM-DD"
    },
    "trustLevel": {
      "type": "string",
      "enum": ["UNTRUSTED", "LOW", "MEDIUM", "HIGH", "SYSTEM"]
    },
    "violationAction": {
      "type": "string",
      "enum": ["ALLOW", "LOG", "REDACT", "ALERT", "BLOCK", "ESCALATE", "DENY"]
    },
    "logLevel": {
      "type": "string",
      "enum": ["OFF", "SUMMARY", "STANDARD", "FULL", "DEBUG"]
    },
    "auditFormat": {
      "type": "string",
      "enum": ["JSON", "OSCAL", "SIEM", "CEF"]
    },
    "complianceFramework": {
      "type": "string",
      "enum": [
        "FedRAMP-Low", "FedRAMP-Moderate", "FedRAMP-High",
        "HIPAA", "SOC2", "EU-AI-Act", "NIST-AI-RMF",
        "ISO-42001", "DPDPA", "CCPA", "PCI-DSS"
      ]
    },
    "threatCategory": {
      "type": "string",
      "enum": [
        "prompt_injection", "jailbreak", "context_stuffing",
        "role_confusion", "data_exfiltration", "adversarial_elicitation"
      ]
    },
    "dataCategory": {
      "type": "string",
      "enum": [
        "PII", "PHI", "SSN", "credit_card", "credentials",
        "date_of_birth", "biometric", "financial",
        "phone_number", "email_address", "ip_addresses",
        "internal_system_refs"
      ]
    }
  },

  "properties": {
    "opengpl": {
      "type": "string",
      "pattern": "^0\\.1$",
      "description": "OpenGPL specification version. Must be '0.1' for this schema."
    },
    "policy": { "$ref": "#/$defs/slug" },
    "version": { "$ref": "#/$defs/semver" },
    "description": { "type": "string", "minLength": 10 },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "REVIEW", "ACTIVE", "DEPRECATED"]
    },
    "owner": { "type": "string", "minLength": 1 },
    "extends": { "$ref": "#/$defs/slug" },

    "applies_to": {
      "type": "object",
      "required": ["models", "contexts"],
      "properties": {
        "models": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "agents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contexts": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "environments": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["development", "staging", "production"]
          }
        },
        "effective_from": { "$ref": "#/$defs/isoDate" },
        "effective_until": { "$ref": "#/$defs/isoDate" }
      }
    },

    "input_controls": {
      "type": "object",
      "properties": {
        "detect": {
          "type": "array",
          "items": { "$ref": "#/$defs/threatCategory" }
        },
        "sanitize": {
          "type": "array",
          "items": { "$ref": "#/$defs/dataCategory" }
        },
        "max_context_tokens": { "type": "integer", "minimum": 1 },
        "max_prompt_tokens": { "type": "integer", "minimum": 1 },
        "allow_system_override": { "type": "boolean" },
        "require_user_auth": { "type": "boolean" },
        "language_filter": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z]{2}$" }
        }
      }
    },

    "model_controls": {
      "type": "object",
      "properties": {
        "allow_tools": { "type": "array", "items": { "type": "string" } },
        "deny_tools": { "type": "array", "items": { "type": "string" } },
        "trust_level": { "$ref": "#/$defs/trustLevel" },
        "require_human_in_loop": { "type": "array", "items": { "type": "string" } },
        "max_tool_calls": { "type": "integer", "minimum": 0 },
        "allow_code_execution": { "type": "boolean" },
        "allow_external_calls": { "type": "boolean" },
        "temperature_ceiling": { "type": "number", "minimum": 0.0, "maximum": 2.0 }
      }
    },

    "output_controls": {
      "type": "object",
      "properties": {
        "block": { "type": "array", "items": { "$ref": "#/$defs/dataCategory" } },
        "redact": { "type": "array", "items": { "$ref": "#/$defs/dataCategory" } },
        "require": { "type": "array", "items": { "type": "string" } },
        "deny_topics": { "type": "array", "items": { "type": "string" } },
        "max_response_tokens": { "type": "integer", "minimum": 1 },
        "hallucination_threshold": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "tone_enforcement": {
          "type": "string",
          "enum": ["professional", "neutral", "formal", "supportive"]
        },
        "deny_formats": { "type": "array", "items": { "type": "string" } }
      }
    },

    "audit": {
      "type": "object",
      "required": ["log_level"],
      "properties": {
        "log_level": { "$ref": "#/$defs/logLevel" },
        "format": { "$ref": "#/$defs/auditFormat" },
        "retention_days": { "type": "integer", "minimum": 1 },
        "compliance": {
          "type": "array",
          "items": { "$ref": "#/$defs/complianceFramework" }
        },
        "pii_in_logs": { "type": "boolean" },
        "evidence_export": { "type": "boolean" },
        "alert_on_violation": { "type": "boolean" },
        "alert_channels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["email", "slack", "pagerduty", "siem", "teams", "webhook"]
          }
        }
      }
    },

    "enforcement": {
      "type": "object",
      "required": ["engine", "on_violation"],
      "properties": {
        "engine": { "type": "string" },
        "on_violation": { "$ref": "#/$defs/violationAction" },
        "on_detection": { "$ref": "#/$defs/violationAction" },
        "fallback": { "$ref": "#/$defs/violationAction" }
      }
    },

    "metadata": {
      "type": "object",
      "properties": {
        "tags": { "type": "array", "items": { "type": "string" } },
        "review_cycle": {
          "type": "string",
          "enum": ["monthly", "quarterly", "bi-annual", "annual"]
        },
        "last_reviewed": { "$ref": "#/$defs/isoDate" },
        "approved_by": { "type": "string" }
      }
    }
  },

  "additionalProperties": false
}
